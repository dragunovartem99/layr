{
	"manifest_version": 3,
	"name": "Layr",
	"version": "0.1.0",
	"description": "dataLayer inspector",
	"permissions": ["activeTab", "scripting"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"world": "MAIN",
			"run_at": "document_end"
		}
	],
	"action": {
		"default_title": "Layr",
		"default_icon": {
			"16": "icons/16.png",
			"48": "icons/48.png",
			"128": "icons/128.png"
		}
	},
	"background": {
		"service_worker": "background.js"
	},
	"icons": {
		"16": "icons/16.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	}
}
