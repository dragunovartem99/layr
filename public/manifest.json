{
	"manifest_version": 3,
	"name": "Layr",
	"version": "0.2.4",
	"description": "Lightweight dataLayer inspector for developers and analytics engineers",
	"permissions": ["sidePanel", "storage"],
	"side_panel": {
		"default_path": "sidepanel.html"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content-main.js"],
			"world": "MAIN",
			"run_at": "document_start"
		},
		{
			"matches": ["<all_urls>"],
			"js": ["content-isolated.js"],
			"world": "ISOLATED",
			"run_at": "document_start"
		}
	],
	"action": {
		"default_title": "Layr",
		"default_icon": {
			"16": "icons/16.png",
			"48": "icons/48.png",
			"128": "icons/128.png"
		}
	},
	"background": {
		"service_worker": "background.js"
	},
	"icons": {
		"16": "icons/16.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	}
}
